---
import { Sun, Moon } from "@lucide/astro";
---

<header class="sticky top-0 z-10 w-full py-4 px-2">
    <div
        class="mx-auto flex items-center justify-between w-fit border border-zinc-200 dark:border-zinc-700/60 rounded-xl bg-white/70 dark:bg-zinc-900/70 backdrop-blur-md px-4 py-2 gap-4 shadow-sm"
    >
        <!-- Navigation -->
        <nav class="flex items-center gap-0.5">
            <a
                href="#home"
                class="text-xs font-medium text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 px-2.5 py-1.5 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all"
            >
                Home
            </a>
            <a
                href="#experience"
                class="text-xs font-medium text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 px-2.5 py-1.5 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all"
            >
                Experience
            </a>
            <a
                href="#projects"
                class="text-xs font-medium text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 px-2.5 py-1.5 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all"
            >
                Projects
            </a>

            <div class="w-px h-5 bg-zinc-200 dark:bg-zinc-700 mx-1" />

            <button
                id="theme-toggle"
                aria-label="Toggle theme"
                class="text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 p-1.5 rounded-lg hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-all cursor-pointer"
            >
                <Sun size={18} stroke-width={1.8} class="dark:hidden" />
                <Moon size={18} stroke-width={1.8} class="hidden dark:block" />
            </button>
        </nav>
    </div>
</header>

<script>
    const themeToggleBtn = document.getElementById("theme-toggle");
    const html = document.documentElement;

    if (
        localStorage.theme === "dark" ||
        (!("theme" in localStorage) &&
            window.matchMedia("(prefers-color-scheme: dark)").matches)
    ) {
        html.classList.add("dark");
    } else {
        html.classList.remove("dark");
    }

    themeToggleBtn?.addEventListener("click", () => {
        if (html.classList.contains("dark")) {
            html.classList.remove("dark");
            localStorage.theme = "light";
        } else {
            html.classList.add("dark");
            localStorage.theme = "dark";
        }
    });
</script>

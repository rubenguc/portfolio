---
import { Briefcase, Code2 } from "@lucide/astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { INFO } from "../../info";

const clientProjects = INFO.clientAndCompanyProjects.filter((p) => p.title);
const hasClientProjects = clientProjects.length > 0;
const hasPersonalProjects = INFO.personalProjects.length > 0;
---

<section id="projects" class="py-14 md:py-20">
    <div class="w-full px-8">
        <!-- Section header -->
        <div class="mb-10 md:mb-14 fade-element delay-2">
            <h2
                class="text-3xl md:text-4xl text-zinc-900 dark:text-zinc-100 font-semibold tracking-tight"
            >
                Projects
            </h2>
        </div>

        <!-- Client & Company Projects -->
        {hasClientProjects && (
            <div class="mb-12 md:mb-16">
                <div class="flex items-center gap-2 mb-5">
                    <Briefcase
                        size={16}
                        class="text-zinc-400 dark:text-zinc-500"
                    />
                    <h3
                        class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-widest"
                    >
                        Client &amp; Company Projects
                    </h3>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
                    {clientProjects.map((project, i) => (
                        <ProjectCard
                            project={project}
                            index={i}
                            defaultColor="#71717a"
                        />
                    ))}
                </div>
            </div>
        )}

        <!-- Personal Projects -->
        {hasPersonalProjects && (
            <div>
                <div class="flex items-center gap-2 mb-5">
                    <Code2
                        size={16}
                        class="text-zinc-400 dark:text-zinc-500"
                    />
                    <h3
                        class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-widest"
                    >
                        Personal Projects
                    </h3>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
                    {INFO.personalProjects.map((project, i) => (
                        <ProjectCard
                            project={project}
                            index={i + clientProjects.length}
                        />
                    ))}
                </div>
            </div>
        )}
    </div>
</section>
